# Schadenportal – Umgebungsvariablen (Vorlage)
# Diese Datei ins Repo einchecken. Die echte .env NIEMALS einchecken!

# Port (Standard: 3000)
PORT=3000

# Session-Secret: Langen zufaelligen String verwenden!
# Generieren: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=HIER_EINEN_LANGEN_ZUFAELLIGEN_STRING_EINSETZEN

# Admin-Account (wird beim ersten Start automatisch angelegt)
ADMIN_EMAIL=admin@schindelhauer.de
ADMIN_PASSWORD=SICHERES_PASSWORT_EINSETZEN

# Redis Session-Store — optional (fuer Produktion empfohlen)
# Wenn nicht gesetzt: lokaler FileStore (nur fuer Entwicklung)
REDIS_URL=redis://localhost:6379

# Umgebung (development / production)
NODE_ENV=development

# Persistente Verzeichnisse — fuer Railway Volume-Mount setzen
DATA_DIR=
UPLOADS_DIR=

# E-Mail (Nodemailer SMTP) — fuer Kundenbenachrichtigungen
SMTP_HOST=smtp.beispiel.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=portal@schindelhauer.de
SMTP_PASS=SMTP_PASSWORT_EINSETZEN
SMTP_FROM=portal@schindelhauer.de
SMTP_FROM_NAME=Felix Schindelhauer GmbH

# App-URL (fuer E-Mail-Links)
APP_URL=https://schaden.schindelhauer.de
