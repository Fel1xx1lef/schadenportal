# Kundenportal – Umgebungsvariablen (Vorlage)
# Diese Datei ins Repo einchecken. Die echte .env NIEMALS einchecken!

# Port (Standard: 3002)
PORT=3002

# Session-Secret: Langen zufälligen String verwenden!
# Generieren z.B. mit: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=HIER_EINEN_LANGEN_ZUFAELLIGEN_STRING_EINSETZEN

# Admin-Account (wird beim ersten Start automatisch angelegt)
ADMIN_EMAIL=admin@beispiel.de
ADMIN_PASSWORD=SICHERES_PASSWORT_EINSETZEN

# TOTP-Secret Verschlüsselung (AES-256-GCM) — optional, aber empfohlen
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=HIER_64_HEX_ZEICHEN_EINSETZEN

# Redis Session-Store — optional (für Produktion empfohlen)
# Wenn nicht gesetzt: lokaler FileStore (nur für Entwicklung)
REDIS_URL=redis://localhost:6379

# Umgebung (development / production)
NODE_ENV=development

# Persistente Verzeichnisse — für Railway Volume-Mount setzen
# Auf Railway: DATA_DIR=/data/db und UPLOADS_DIR=/data/uploads
# (Volume muss in Railway Dashboard unter "Volumes" angelegt werden)
DATA_DIR=
UPLOADS_DIR=
